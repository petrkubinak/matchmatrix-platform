# ==========================
# MATCHMATRIX .gitignore
# ==========================

# --------------------------
# PYTHON
# --------------------------

**pycache**/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# --------------------------
# ENV / SECRETS
# --------------------------

.env
.env.*
!.env.example

# --------------------------
# LOGS & RUNTIME OUTPUT
# --------------------------

logs/
*.log

# --------------------------
# DATA (RAW / STAGING / EXPORT)
# --------------------------

data/
data/raw/
data/staging/
data/exports/

# Keep empty folder structure if needed

!data/.gitkeep

# --------------------------
# REPORTS (GENERATED)
# --------------------------

reports/

# Keep structure if needed

!reports/.gitkeep

# --------------------------
# DATABASE DUMPS / BACKUPS
# --------------------------

*.sql.dump
*.dump
*.backup
backups/
Dump/
MatchMatrix-platform/Dump/

# --------------------------
# DOCKER VOLUMES
# --------------------------

postgres-data/
redis-data/

# --------------------------
# IDE / EDITORS
# --------------------------

.vscode/
.idea/

# --------------------------
# OS FILES
# --------------------------

Thumbs.db
.DS_Store

# --------------------------
# TEMP / CACHE
# --------------------------

*tmp**
*.tmp
*.cache

# --------------------------
# OPTIONAL (large binaries)
# --------------------------

*.zip
*.tar
*.gz
